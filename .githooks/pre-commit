#!/bin/sh
set -e

# Auto-regenerate termbase_i18n.md when glossary.md is staged.

if git diff --cached --name-only | grep -q "^writing-guides/glossary.md$"; then
    echo "glossary.md changed — regenerating termbase_i18n.md..."
    python3 tools/translate/derive-termbase.py
    git add tools/translate/termbase_i18n.md
    echo "termbase_i18n.md regenerated and staged."
fi
